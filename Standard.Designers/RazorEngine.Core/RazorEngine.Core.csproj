		<AssemblyName>RazorEngine.Core</AssemblyName>
		<RootNamespace>RazorEngine</RootNamespace>
		<DelaySign>false</DelaySign>
		<GeneratePackageOnBuild>False</GeneratePackageOnBuild>
	</PropertyGroup>
	<ItemGroup>
