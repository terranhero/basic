<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"    
	xmlns:sys="clr-namespace:System;assembly=mscorlib"
    xmlns:bw="clr-namespace:Basic.Windows"
    xmlns:enums="clr-namespace:Basic.Enums"
    xmlns:ui="clr-namespace:Microsoft.VisualStudio.PlatformUI;assembly=Microsoft.VisualStudio.Shell.15.0">
	<Style TargetType="{x:Type bw:CreatePersistent}" BasedOn="{StaticResource  {x:Type ui:DialogWindowBase}}">
		<Setter Property="Title" Value="添加数据持久类"/>
		<Setter Property="Background" Value="#FFE8EDF9"/>
		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="{x:Type bw:CreatePersistent}">
					<ControlTemplate.Resources>
						<Style TargetType="{x:Type ComboBox}" >
							<Setter Property="Padding"  Value="3" />
							<Setter Property="Margin"  Value="0,5" />
							<Setter Property="Height" Value="27"/>
							<Setter Property="VerticalAlignment" Value="Center"/>
							<Setter Property="FontSize" Value="15"/>
						</Style>
						<Style TargetType="TextBox">
							<Setter Property="AcceptsReturn" Value="True"/>
							<Setter Property="TextWrapping" Value="Wrap"/>
							<Setter Property="HorizontalScrollBarVisibility" Value="Auto"/>
							<Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
							<Setter Property="BorderThickness" Value="1,0,1,1"/>
							<Setter Property="Padding"  Value="10" />
						</Style>
					</ControlTemplate.Resources>
					<Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" 
                        BorderThickness="{TemplateBinding BorderThickness}" Padding="15,15,10,15">
						<!-- 标题栏（必需） -->
						<!--<ui:DialogTitleBar Grid.Row="0" 
                                           Background="{DynamicResource {x:Static ui:EnvironmentColors.MainWindowActiveCaptionBrushKey}}"
                                           Foreground="{DynamicResource {x:Static ui:EnvironmentColors.MainWindowActiveCaptionTextBrushKey}}"
                                           Caption="{TemplateBinding Title}"/>-->
						<Grid Background="#FFE8EDF9">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="Auto"/>
								<ColumnDefinition Width="Auto"/>
							</Grid.ColumnDefinitions>
							<Grid.RowDefinitions>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="*"/>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="Auto"/>
							</Grid.RowDefinitions>
							<ComboBox x:Name="cmbConnections" Grid.Row="0" Grid.ColumnSpan="3"
              DisplayMemberPath="DisplayName" Margin="0,5,5,5"  />
							<ListBox Grid.Row="1" Grid.ColumnSpan="3" x:Name="lstTables" Margin="0,5,5,5"
						 DisplayMemberPath="TableName" SelectedValuePath="TableName"/>
							<Label Grid.Row="2" Grid.ColumnSpan="3" Content="名称"/>
							<TextBox Grid.Row="3" Grid.ColumnSpan="3" 
             DataContext="{TemplateBinding SelectedTable}" Margin="0,5,5,5" 
             Text="{Binding EntityName,Mode=TwoWay}"/>
							<ui:DialogButton Grid.Row="4" Grid.Column="1"  Content="添  加..." Command="Save" IsEnabled="{TemplateBinding CanSave}"/>
							<ui:DialogButton Grid.Row="4" Grid.Column="2"  Content="取  消" Command="Close" IsCancel="True"/>
						</Grid>
					</Border>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>
</ResourceDictionary>