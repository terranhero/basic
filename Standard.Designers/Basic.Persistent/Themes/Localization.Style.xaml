<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"    
	xmlns:sys="clr-namespace:System;assembly=mscorlib"
    xmlns:bl="clr-namespace:Basic.Localizations"
    xmlns:enums="clr-namespace:Basic.Enums"
    xmlns:ui="clr-namespace:Microsoft.VisualStudio.PlatformUI;assembly=Microsoft.VisualStudio.Shell.15.0">
	<Style TargetType="{x:Type bl:LocalizationDialog}" BasedOn="{StaticResource  {x:Type ui:DialogWindow}}">
		<Setter Property="Title" Value="添加本地化资源文件"/>
		<Setter Property="Background" Value="#FFE8EDF9"/>
		<Setter Property="Content">
			<Setter.Value>
				<StackPanel Margin="30">
					<TextBox x:Name="PART_NAME" Padding="8" Text="{Binding FileName, Mode=TwoWay}" />
					<TextBlock   Foreground="Red" Margin="0,5,0,0" Text="{Binding ErrorText}" TextWrapping="WrapWithOverflow"/>
					<Button Content="确定" Margin="0,20,0,0" Padding="40,10,40,10" HorizontalAlignment="Right" Command="Save"/>
				</StackPanel>
			</Setter.Value>
		</Setter>
