<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"    
	xmlns:sys="clr-namespace:System;assembly=mscorlib"
    xmlns:bd="clr-namespace:Basic.Designer"
    xmlns:enums="clr-namespace:Basic.Enums"
    xmlns:ui="clr-namespace:Microsoft.VisualStudio.PlatformUI;assembly=Microsoft.VisualStudio.Shell.15.0">
	<Style TargetType="{x:Type bd:WithClauseDialog}" BasedOn="{StaticResource  {x:Type ui:DialogWindow}}">
		<Setter Property="Title" Value="修改 CommandText 属性的值"/>
		<Setter Property="Background" Value="#FFE8EDF9"/>
		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="{x:Type bd:WithClauseDialog}">
					<ControlTemplate.Resources>
						<Style TargetType="{x:Type TextBlock}">
							<Setter Property="Margin" Value="6"/>
						</Style>
						<Style TargetType="{x:Type TextBox}">
							<Setter Property="Margin" Value="6"/>
							<Setter Property="FontSize" Value="12"/>
							<Setter Property="Padding" Value="2"/>
						</Style>
					</ControlTemplate.Resources>
					<Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" 
                        BorderThickness="{TemplateBinding BorderThickness}" Padding="5">
						<Grid Background="#FFE8EDF9">
							<Grid.RowDefinitions>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="*"/>
								<RowDefinition Height="Auto"/>
							</Grid.RowDefinitions>
							<TextBlock Grid.Row="0" Text="获取或设置 WITH 临时结果集的表名称(TableName)" VerticalAlignment="Center"/>
							<TextBox Grid.Row="1" Text="{Binding TableName, Mode=TwoWay}"/>
							<TextBlock Grid.Row="2" Text="获取或设置 WITH 临时结果集的表定义(TableDefinition)"/>
							<TextBox Grid.Row="3" Text="{Binding TableDefinition, Mode=TwoWay}"/>
							<TextBlock Grid.Row="4" Text="获取或设置 WITH 临时结果集的表查询(TableQuery)"/>
							<TextBox Grid.Row="5" AcceptsReturn="True" Text="{Binding TableQuery, Mode=TwoWay}" TextWrapping="Wrap" />
							<StackPanel Grid.Row="6" Orientation="Horizontal" Margin="6" HorizontalAlignment="Right">
								<Button Height="30" Width="90" Margin="30,0,0,0" FontSize="14" Command="Delete">删 除</Button>
								<Button Height="30" Width="90" Margin="30,0,0,0" FontSize="14" Command="Close">关 闭</Button>
							</StackPanel>
						</Grid>
					</Border>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>
</ResourceDictionary>